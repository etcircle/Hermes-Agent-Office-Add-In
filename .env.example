# Local bridge ports
OFFICE_ADDIN_HTTP_PORT=3300
OFFICE_ADDIN_HTTPS_PORT=3446

# Local bridge session config
OFFICE_ADDIN_PASSPHRASE=replace-me
OFFICE_ADDIN_SESSION_EXPIRY_HOURS=12

# Hermes backend target used by the local bridge
HERMES_API_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=replace-me
HERMES_API_AUTH_HEADER=x-api-key
HERMES_API_AUTH_SCHEME=

# Optional extra allowed origins (comma-separated)
OFFICE_ADDIN_ALLOWED_ORIGINS=https://localhost:3446,http://localhost:3300

# Optional HTTPS cert paths
OFFICE_ADDIN_CERT_FILE=certs/localhost.crt
OFFICE_ADDIN_KEY_FILE=certs/localhost.key
